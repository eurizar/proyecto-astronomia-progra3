@using AstronomiaApp.Services
@inject HistorialService Historial
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var act  = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string Nav(string c, string a) =>
        (ctrl == c && act == a)
            ? "nav-link text-warning fw-semibold border-bottom border-warning pb-0"
            : "nav-link text-secondary";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Astronomía</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/estilos.css" asp-append-version="true" />
</head>
<body class="bg-dark text-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-black border-bottom border-secondary mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-warning" asp-controller="Objetos" asp-action="Index">
                    &#9733; Astronomía
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-label="Menú">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="@Nav("Objetos","Index")" asp-controller="Objetos" asp-action="Index">Catálogo</a>
                        </li>
                        <li class="nav-item">
                            <a class="@Nav("Objetos","Buscar")" asp-controller="Objetos" asp-action="Buscar">Buscar</a>
                        </li>
                        <li class="nav-item">
                            <a class="@Nav("Objetos","BuscarRango")" asp-controller="Objetos" asp-action="BuscarRango">Explorar</a>
                        </li>
                        <li class="nav-item">
                            <a class="@Nav("Grafo","Index")" asp-controller="Grafo" asp-action="Index">Grafo</a>
                        </li>
                        <li class="nav-item">
                            <a class="@Nav("Objetos","Sistema")" asp-controller="Objetos" asp-action="Sistema">Sistema 3D</a>
                        </li>
                        <li class="nav-item">
                            <a class="@Nav("Admin","Consultas")" asp-controller="Admin" asp-action="Consultas">Bitácora</a>
                        </li>
                    </ul>
                    @{
                        var historial = Historial.ObtenerHistorial().ToList();
                    }
                    @if (historial.Any())
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-secondary" href="#" data-bs-toggle="dropdown">
                                    Visitados (@historial.Count)
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end">
                                    @foreach (var e in historial)
                                    {
                                        <li><a class="dropdown-item small" href="@e.Url">@e.Nombre</a></li>
                                    }
                                </ul>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-secondary footer text-muted mt-4 py-2">
        <div class="container text-center small">
            Sistema de Exploración Astronómica &mdash; Programación III &mdash; UMG Cobán 2026
        </div>
    </footer>

    @* <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/api.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
