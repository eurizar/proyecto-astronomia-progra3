@model AstronomiaApp.Models.ViewModels.GrafoViewModel
@{
    ViewData["Title"] = "Grafo de Relaciones";
}

<style>
    body {
        background: radial-gradient(circle at top, #111827 0%, #020617 55%, #000 100%);
    }

    .grafo-page {
        color: #e5e7eb;
    }

    .grafo-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 16px;
    }

    .grafo-title {
        color: #ffc107;
        font-weight: 800;
        text-shadow: 0 0 18px rgba(255, 193, 7, .55);
        margin: 0;
    }

    .grafo-badge {
        padding: 10px 18px;
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, .25);
        background: rgba(15, 23, 42, .8);
        box-shadow: 0 0 25px rgba(59, 130, 246, .18);
        color: #cbd5e1;
    }

    .ruta-card {
        border: 1px solid rgba(148, 163, 184, .22);
        background: rgba(15, 23, 42, .82);
        backdrop-filter: blur(12px);
        border-radius: 22px;
        box-shadow: 0 18px 45px rgba(0, 0, 0, .45);
        margin-bottom: 18px;
    }

    .ruta-card .card-body {
        padding: 20px;
    }

    .ruta-title {
        color: #ffc107;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .grafo-select {
        background-color: #020617 !important;
        color: #e5e7eb !important;
        border: 1px solid rgba(148, 163, 184, .35) !important;
        border-radius: 14px !important;
    }

    .grafo-select:focus {
        box-shadow: 0 0 0 .2rem rgba(255, 193, 7, .18) !important;
        border-color: #ffc107 !important;
    }

    .grafo-btn {
        border-radius: 14px;
        font-weight: 700;
        padding-left: 20px;
        padding-right: 20px;
        box-shadow: 0 0 18px rgba(255, 193, 7, .28);
    }

    #resultado-ruta {
        margin-top: 14px;
        padding: 12px 14px;
        border-radius: 14px;
        background: rgba(2, 6, 23, .7);
        border: 1px solid rgba(148, 163, 184, .18);
        color: #e5e7eb;
    }

    .grafo-card {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(148, 163, 184, .25);
        background: #000;
        box-shadow: 0 22px 55px rgba(0, 0, 0, .65);
    }

    #grafo-canvas {
        display: block;
        width: 100%;
        height: 620px;
        cursor: grab;
        background: #000;
    }

    .grafo-help {
        position: absolute;
        left: 18px;
        top: 18px;
        z-index: 2;
        padding: 14px 16px;
        border-radius: 16px;
        background: rgba(2, 6, 23, .72);
        border: 1px solid rgba(148, 163, 184, .22);
        color: #cbd5e1;
        font-size: 13px;
        line-height: 1.8;
        backdrop-filter: blur(8px);
        pointer-events: none;
    }

    @@media (max-width: 768px) {
        .grafo-header {
            flex-direction: column;
            align-items: flex-start;
        }

        #grafo-canvas {
            height: 520px;
        }

        .grafo-help {
            font-size: 12px;
            left: 10px;
            top: 10px;
        }
    }
</style>

<div class="grafo-page">

    <div class="grafo-header">
        <h2 class="grafo-title">Grafo de Relaciones Astronómicas</h2>

        <div class="grafo-badge">
            @Model.Nodos.Count() nodos &bull; @Model.Aristas.Count() aristas
        </div>
    </div>

    <div class="card ruta-card">
        <div class="card-body">
            <h6 class="ruta-title">Calcular rutas</h6>

            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <select id="sel-origen" class="form-select form-select-sm grafo-select">
                        <option value="">— Origen —</option>
                        @foreach (var n in Model.Nodos)
                        {
                            <option value="@n.Id">@n.Nombre</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <select id="sel-destino" class="form-select form-select-sm grafo-select">
                        <option value="">— Destino —</option>
                        @foreach (var n in Model.Nodos)
                        {
                            <option value="@n.Id">@n.Nombre</option>
                        }
                    </select>
                </div>

                <div class="col-auto">
                    <button class="btn btn-sm btn-warning grafo-btn" onclick="calcularRuta()">
                        Calcular
                    </button>
                </div>
            </div>

            <div id="resultado-ruta">Selecciona origen y destino.</div>
        </div>
    </div>

    <div class="grafo-card">
        <canvas id="grafo-canvas"></canvas>
    </div>

</div>

<script id="grafo-data" type="application/json">
{
    "nodos": @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Nodos.Select(n => new { id = n.Id, nombre = n.Nombre, tipo = n.Tipo }))),
    "aristas": @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Aristas.Select(a => new { origen = a.Origen, destino = a.Destino, tipo = a.TipoRelacion, peso = a.Peso })))
}
</script>

@section Scripts {
<script src="~/js/grafo-viewer.js" asp-append-version="true"></script>

<script>
async function calcularRuta() {
    const origen = document.getElementById('sel-origen').value;
    const destino = document.getElementById('sel-destino').value;
    const div = document.getElementById('resultado-ruta');

    if (!origen || !destino) {
        div.textContent = 'Selecciona origen y destino.';
        return;
    }

    try {
        const r = await fetch(`/api/grafo/ruta?origen=${origen}&destino=${destino}`);

        if (!r.ok) {
            div.innerHTML = '<span class="text-danger">No existe ruta entre esos objetos.</span>';
            return;
        }

        const d = await r.json();

        div.innerHTML = `<strong class="text-warning">Ruta:</strong> ${d.ruta.join(' → ')}
            &nbsp;|&nbsp; <strong>Distancia total:</strong> ${d.distanciaTotal.toFixed(4)} UA
            &nbsp;|&nbsp; <strong>Saltos:</strong> ${d.saltos}`;

        if (window.resaltarRutaGrafo) {
            window.resaltarRutaGrafo(d.ruta);
        }

    } catch(e) {
        div.innerHTML = '<span class="text-danger">Error al calcular ruta.</span>';
    }
}
</script>
}